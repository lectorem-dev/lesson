COMPOSE_PROJECT_NAME=lesson

POSTGRES_DB=lesson
POSTGRES_USER=lesson
POSTGRES_PASSWORD=lesson
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=3000

# Секрет для подписи JWT. Для реального окружения замените на длинную случайную строку.
JWT_SECRET=change-this-secret-key-to-long-random-string

# Базовый URL API для фронтенда. Значение /api удобно для запуска через nginx-прокси в Docker.
VITE_API_BASE_URL=/api
